powershell -Command "$nextRun=(Get-Date); while ($true) { $now=Get-Date; $status='WAITING'; if ($now.DayOfWeek -ge 'Monday' -and $now.DayOfWeek -le 'Friday' -and $now.TimeOfDay -ge '09:15' -and $now.TimeOfDay -le '15:30') { $status='RUNNING'; Write-Host "`n[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $status - Executing fetch-snapshot.py..." -ForegroundColor Green; python fetch-snapshot.py } else { $status='IDLE (Outside trading hours/weekend)'; Write-Host "`r[$(Get-Date -Format 'HH:mm:ss')] $status - Next run in: $([math]::Round((($nextRun.AddSeconds(900) - $now).TotalSeconds),0)) seconds     " -NoNewline -ForegroundColor Yellow }; $nextRun=$now; Start-Sleep -Seconds 900 }"